# anneal uses its own credentials. Never copy keys here from another project's .env.
# These are YOUR personal keys.
#
# ANTHROPIC_API_KEY: required for tiers "balanced" (Haiku 4.5) and "premium" (Sonnet 4.6).
# OPENROUTER_API_KEY: required for tier "cheap" and for the Judge role in tier "balanced".
# Get an OpenRouter key at openrouter.ai/keys.
#
# GEMINI_API_KEY: required for tier "cheap-gemini" and any per-role override targeting a
# Gemini model via the "gemini" provider (direct Google API, not via OpenRouter).
# Get a key at aistudio.google.com/app/apikey (free tier available).
# Install the SDK first: pip install anneal[gemini]  (or: pip install google-genai)

ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
